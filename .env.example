VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional
VITE_RECAPTCHA_SITE_KEY=
VITE_APPCHECK_DEBUG_TOKEN=
VITE_ALLOWED_DOMAIN=
VITE_ALLOWED_EMAILS=
VITE_SUPER_ADMIN=admin@example.com

# Demo login (optional)
# Set both to show a "Demo access" box on the login screen with one-click sign-in.
# Steps: 1) Enable Email/Password auth in Firebase Console → Authentication → Sign-in methods
#         2) Create the demo user in Firebase Console → Authentication → Users
#         3) Add the demo email to VITE_ALLOWED_EMAILS (if you use an allowlist)
VITE_DEMO_EMAIL=
VITE_DEMO_PASSWORD=
